#!/usr/bin/env sh

##############################################################################
##
##  Gradle start up script for POSIX generated by Gradle.
##
##############################################################################

set -e

APP_NAME="Gradle"
APP_BASE_NAME=$(basename "$0")

DEFAULT_JVM_OPTS='"-Xmx64m" "-Xms64m"'

MAX_FD="maximum"

warn () {
    echo "$*"
}

die () {
    echo
    echo "$*"
    echo
    exit 1
}

cygwin=false
msys=false
darwin=false
nonstop=false
case "$(uname)" in
  CYGWIN* ) cygwin=true ;;
  Darwin* ) darwin=true ;;
  MSYS* | MINGW* ) msys=true ;;
  NONSTOP* ) nonstop=true ;;
esac

CLASSPATH=$APP_HOME/gradle/wrapper/gradle-wrapper-main.jar:$APP_HOME/gradle/wrapper/gradle-wrapper-shared.jar

APP_HOME=$(cd "$(dirname "$0")" && pwd)

if [ ! -r "$APP_HOME/gradle/wrapper/gradle-wrapper-main.jar" ] || [ ! -r "$APP_HOME/gradle/wrapper/gradle-wrapper-shared.jar" ]; then
  die "Missing Gradle wrapper jars.
Expected:
  gradle/wrapper/gradle-wrapper-main.jar
  gradle/wrapper/gradle-wrapper-shared.jar"
fi

if [ "$cygwin" = "true" -o "$msys" = "true" ] ; then
    APP_HOME=$(cygpath --path --mixed "$APP_HOME")
    CLASSPATH=$(cygpath --path --mixed "$CLASSPATH")
fi

JAVA_HOME=${JAVA_HOME:-}
if [ -z "$JAVA_HOME" ] ; then
    JAVA_EXE=$(command -v java || true)
    [ -n "$JAVA_EXE" ] || die "JAVA_HOME is not set and no 'java' command could be found."
else
    JAVA_EXE="$JAVA_HOME/bin/java"
fi

exec "$JAVA_EXE" $DEFAULT_JVM_OPTS $JAVA_OPTS $GRADLE_OPTS \
  -classpath "$CLASSPATH" org.gradle.wrapper.GradleWrapperMain "$@"

